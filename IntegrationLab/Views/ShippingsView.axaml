<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:IntegrationLab.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="IntegrationLab.Views.ShippingsView"
             x:DataType="vm:ShippingsViewModel"
             DataContext="{DynamicResource ViewModel}">
    <UserControl.Resources>
        <vm:ShippingsViewModel x:Key="ViewModel"/>
    </UserControl.Resources>
    <Grid RowDefinitions="*">
        <ListBox ItemsSource="{Binding Shippings}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="{Binding EstimatedDeliveryDate, StringFormat={}Дата прибытия: dd.MM.yyyy}"/>
                        <Label Content="{Binding Cargos.Count, StringFormat={}Количество груза: {0}}"/>
                        <Label Content="{Binding ConfirmedStatus}"/>
                        <Button Content="Подтвердить" 
                                Command="{Binding ConfirmShippingCommand, 
                                RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=vm:ShippingsViewModel}}"
                                CommandParameter="{Binding .}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
