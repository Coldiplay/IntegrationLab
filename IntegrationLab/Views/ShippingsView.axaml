<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:IntegrationLab.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="IntegrationLab.Views.ShippingsView"
             x:DataType="vm:ShippingsViewModel">
    <Grid RowDefinitions="* *">
        <ListBox SelectedItem="{Binding SelectedShipping}" 
                 ItemsSource="{Binding Shippings}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="{Binding EstimatedDeliveryDate, StringFormat={}Дата прибытия: dd.MM.yyyy}"/>
                        <Label Content="{Binding Cargos.Count, StringFormat={}Количество груза: {0}}"/>
                        <Label Content="{Binding ConfirmedStatus}"/>
                        <!-- <Button Content="Подтвердить"  -->
                        <!--         Command="{Binding ConfirmShippingCommand,  -->
                        <!--         RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=vm:ShippingsViewModel}}"/> -->
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Подтвердить" 
                              Command="{Binding ConfirmShippingCommand}"
                              CommandParameter="{Binding SelectedShipping}"
                    />
                </ContextMenu>
            </ListBox.ContextMenu>
        </ListBox>
    </Grid>
</UserControl>
