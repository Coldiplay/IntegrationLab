<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:IntegrationLab.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="IntegrationLab.Views.SingleIncidentView"
             x:DataType="vm:SingleIncidentViewModel">
    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
         to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:SingleIncidentViewModel />
    </Design.DataContext>
    
    <Grid RowDefinitions="Auto *">
        <!--TODO: Потом поставить иконку назад -->
        <Button Content="Назад" Command="{Binding ReturnToIncidentsListCommand}"/>
        
        <StackPanel Grid.Row="1">
            <!-- <Label>Чтонибудь про инцидент</Label> -->
            <Label Content="{Binding Incident.IncidentDate}"/>
            <Label Content="{Binding Incident.Status,
            Converter={StaticResource IncidentStatusConverter}, 
            StringFormat={}Статус: {0}}"/>
            <Label Content="{Binding Incident.Shipping.Vehicle.VehicleFullName, 
            StringFormat={}ТС: {0}}"/>
            <Label Content="Описание: "/>
            <TextBlock Text="{Binding Incident.Description}" TextWrapping="WrapWithOverflow"/>
        </StackPanel>
    </Grid>
    
</UserControl>
