<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:IntegrationLab.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="IntegrationLab.Views.ActiveShippingView"
             x:DataType="vm:ActiveShippingViewModel">
    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
         to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:ActiveShippingViewModel />
    </Design.DataContext>
    
    <StackPanel>
        <StackPanel.Styles>
            <Style Selector="Label">
                <Setter Property="Margin" Value="5"/>
            </Style>
        </StackPanel.Styles>
        
        <Label Content="Текущий рейс"/>
        <Label Content="{Binding ActiveShipping.Vehicle.VehicleFullName, 
        StringFormat={}Назначенное ТС: {0}}"/>
        <Label Content="{Binding ActiveShipping.DeliveryPoint, 
        StringFormat={}Адрес: {0}}"/>
        <Label Content="{Binding ActiveShipping.DeliveryDate, 
        StringFormat={}Дата доставки: dd.MM.yyyy}"/>
        <Label Content="Перевозимый груз:"/>
        <ScrollViewer>
            <ListBox ItemsSource="{Binding ActiveShipping.Cargos}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Label Content="{Binding Name}"/>
                            <Label Content="{Binding CargoType.Title, StringFormat={}Тип: {0}}"/>
                            <!-- <Label Content="{Binding  Dimensions}"/> -->
                            <Label Content="{Binding Weight, StringFormat={}Масса: {0} кг}"/>
                            <Label Content="{Binding DangerLevel, 
                            Converter={StaticResource DangerLevelConverter},
                            ConverterParameter=true}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>
    </StackPanel>
</UserControl>
